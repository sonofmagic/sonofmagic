{
  "name": "monorepo-template",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "author": "ice breaker <1324318532@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonofmagic/monorepo-template.git"
  },
  "bugs": {
    "url": "https://github.com/sonofmagic/monorepo-template/issues"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "vitest run --coverage.enabled",
    "test:dev": "vitest",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check:fixed-versions": "node scripts/check-fixed-package-versions.mjs",
    "release": "changeset",
    "publish-packages": "pnpm check:fixed-versions && turbo run lint typecheck build test && changeset version && pnpm check:fixed-versions && changeset publish",
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "commit": "commit",
    "-------": "-----------",
    "pr:alpha": "changeset pre enter alpha",
    "pr:beta": "changeset pre enter beta",
    "pr:rc": "changeset pre enter rc",
    "pr:exit": "changeset pre exit",
    "--------": "----------------",
    "script:init": "monorepo init",
    "script:sync": "monorepo sync",
    "script:clean": "monorepo clean",
    "script:mirror": "monorepo mirror",
    "start": "pnpm --filter @icebreakers/svg build && node index.js",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.0.1",
    "@icebreakers/changelog-github": "^1.0.2",
    "@icebreakers/commitlint-config": "^3.0.1",
    "@icebreakers/eslint-config": "^5.0.1",
    "@icebreakers/monorepo": "^4.0.8",
    "@icebreakers/stylelint-config": "^4.0.1",
    "@icebreakers/svg": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.8.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "~4.1.6",
    "ci-info": "^4.4.0",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.20",
    "defu": "^6.1.7",
    "es-toolkit": "^1.46.1",
    "eslint": "^10.3.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "markdown-table": "^3.0.4",
    "only-allow": "^1.2.2",
    "pathe": "^2.0.3",
    "pkg-types": "^2.3.1",
    "rimraf": "^6.1.3",
    "stylelint": "^17.11.1",
    "tsdown": "0.22.0",
    "tslib": "^2.8.1",
    "tsx": "^4.22.0",
    "turbo": "^2.9.14",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "~4.1.6",
    "yaml": "^2.9.0"
  },
  "pnpm": {
    "overrides": {
      "boxen@8.0.1>cli-boxes": "4.0.1"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
